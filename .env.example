# --- Database ---
# Local Postgres example. The DB must have the btree_gist extension installed.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/carwash?schema=public"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# --- Stripe (optional in dev) ---
# Leave blank to use the in-process mock. Set real keys to hit live Stripe.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
PLATFORM_FEE_BPS="2000" # 2000 bps = 20% commission

# --- Maps (optional) ---
NEXT_PUBLIC_MAPBOX_TOKEN=""
